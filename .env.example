# PostHog (required)
# Get your API key at https://app.posthog.com/project/settings → Personal API keys
POSTHOG_API_KEY=phx_your_personal_api_key_here

# PostHog Project ID (numeric). Get from project settings URL.
POSTHOG_PROJECT_ID=12345

# PostHog host (default: https://us.i.posthog.com)
# EU users: https://eu.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com
