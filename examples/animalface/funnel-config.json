{
  "automation": {
    "enabled": true,
    "auto_merge": false,
    "max_concurrent_experiments": 1,
    "min_sample_size": 500,
    "significance_level": 0.05,
    "min_early_decision_days": 3,
    "experiment_duration_days": 7,
    "max_experiment_days": 14,
    "analysis_days": 7
  },
  "optimization_targets": [
    {
      "kpi": "premium_paid_rate",
      "metric_name": "Premium Paid Rate (real revenue)",
      "impression_event": "result_view",
      "click_events": ["premium_paid"],
      "current": 0,
      "target": 1.0,
      "priority": "P0",
      "direction": "higher",
      "_note": "분모=result_view, 분자=premium_paid(리포트 발급 후 첫 조회). CTA CTR 같은 proxy가 아닌 실제 수익 전환율"
    },
    {
      "kpi": "checkout_paid_rate",
      "metric_name": "Checkout → Paid Conversion",
      "impression_event": "premium_checkout",
      "click_events": ["premium_paid"],
      "current": 0,
      "target": 50.0,
      "priority": "P0",
      "direction": "higher",
      "_note": "체크아웃 진입자 중 실제 결제 완료율. 0%는 Stripe 결제 시스템 자체 문제 진단 지표"
    },
    {
      "kpi": "premium_cta_ctr",
      "metric_name": "Premium CTA CTR (proxy)",
      "impression_event": "premium_cta_impression",
      "click_events": ["premium_click"],
      "current": 1.26,
      "target": 4.0,
      "priority": "P2",
      "direction": "higher",
      "_note": "클릭 proxy. 실제 매출과 괴리 발생한 이력 있음 (2026-04-19). P0는 premium_paid_rate 사용"
    },
    {
      "kpi": "share_total_ctr",
      "metric_name": "Share Total CTR",
      "impression_event": "share_button_impression",
      "click_events": ["result_share", "share_copy_link"],
      "current": 1.09,
      "target": 8.0,
      "priority": "P3",
      "direction": "higher"
    },
    {
      "kpi": "retry_upsell_ctr",
      "metric_name": "Retry Upsell CTR",
      "impression_event": "retry_upsell_impression",
      "click_events": ["retry_upsell_click"],
      "current": 0.36,
      "target": 2.0,
      "priority": "P4",
      "direction": "higher"
    },
    {
      "kpi": "desktop_upload_rate",
      "metric_name": "Desktop Upload Rate",
      "impression_event": "$pageview",
      "click_events": ["photo_upload"],
      "current": 39.05,
      "target": 70.0,
      "priority": "P5",
      "direction": "higher",
      "device_filter": "Desktop"
    }
  ],
  "guardrails": {
    "no_dark_patterns": true,
    "no_fake_urgency": true,
    "no_fake_social_proof": true,
    "preserve_accessibility": true,
    "max_code_changes": 5,
    "allowed_files": [
      "src/components/AnimalFaceTest.tsx",
      "src/components/PremiumResultDisplay.tsx",
      "src/lib/translations.ts",
      "src/styles/global.css"
    ]
  },
  "multi_agent": {
    "enabled": true,
    "agents": ["claude", "codex", "gemini"],
    "timeout_seconds": 1800,
    "auto_select_threshold": 10,
    "human_review_threshold": 5,
    "fallback_agent": "claude",
    "preserve_losing_proposal": true,
    "scoring_weights": {
      "completeness": 15,
      "schema_validity": 20,
      "code_validity": 25,
      "guardrail_compliance": 15,
      "kpi_alignment": 10,
      "novelty": 10,
      "analysis_depth": 5
    }
  },
  "value_metrics": {
    "lir": {
      "name": "Leading Indicator of Retention",
      "description": "사용자가 실질적 가치를 경험했음을 예측하는 행동 지표",
      "definition": "결과 확인 후 공유 완료 OR 프리미엄 결제 완료 OR 재시도(retry) 수행",
      "events": ["result_share", "share_copy_link", "premium_checkout", "retry_click"],
      "denominator_event": "result_view",
      "target_rate": 15,
      "current": null,
      "rationale": "결과를 보고 추가 행동(공유/결제/재시도)을 한 사용자는 가치를 경험한 것으로, 재방문 및 바이럴 전파 가능성이 높음"
    },
    "time_to_value": {
      "name": "Time-to-Value",
      "description": "사용자가 핵심 가치(결과 확인)에 도달하는 데 걸리는 시간",
      "milestones": {
        "page_to_upload": {
          "start": "$pageview",
          "end": "photo_upload",
          "target_seconds": 30,
          "description": "방문 → 사진 업로드"
        },
        "upload_to_result": {
          "start": "photo_upload",
          "end": "result_view",
          "target_seconds": 15,
          "description": "업로드 → 결과 확인 (Aha Moment)"
        },
        "total": {
          "start": "$pageview",
          "end": "result_view",
          "target_seconds": 60,
          "description": "방문 → 결과 확인 (전체 TTV)"
        }
      }
    },
    "health_rollup": {
      "name": "Weekly Health Rollup",
      "description": "주간 사용자 건강도 세그먼트 분류",
      "segments": {
        "activated": {
          "description": "결과 확인 + 추가 행동 (공유/결제/재시도)",
          "condition": "result_view AND (result_share OR share_copy_link OR premium_checkout OR retry_click)"
        },
        "completed": {
          "description": "결과 확인까지 도달했으나 추가 행동 없음",
          "condition": "result_view AND NOT (result_share OR share_copy_link OR premium_checkout OR retry_click)"
        },
        "stuck": {
          "description": "업로드했으나 결과를 보지 못함",
          "condition": "photo_upload AND NOT result_view"
        },
        "bounced": {
          "description": "방문했으나 업로드하지 않음",
          "condition": "$pageview AND NOT photo_upload"
        }
      }
    }
  },
  "posthog": {
    "host": "https://us.i.posthog.com",
    "feature_flag_prefix": "funnel-exp-"
  }
}
